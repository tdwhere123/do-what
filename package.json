{
  "name": "do-what",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "packageManager": "pnpm@10.27.0",
  "workspaces": [
    "packages/*",
    "packages/engines/*"
  ],
  "scripts": {
    "build": "turbo build",
    "test": "turbo test",
    "typecheck": "turbo typecheck",
    "dev:core": "pnpm --filter @do-what/core start",
    "dev:app": "pnpm --filter @do-what/app start"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "electron",
      "better-sqlite3"
    ]
  },
  "devDependencies": {
    "@do-what/core": "workspace:*",
    "@types/node": "^24.3.1",
    "turbo": "^2.5.6",
    "typescript": "^5.9.2",
    "vitest": "^3.2.4"
  },
  "volta": {
    "node": "22.22.1"
  }
}
