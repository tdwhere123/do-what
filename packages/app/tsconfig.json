{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "jsx": "react-jsx",
    "lib": ["DOM", "ES2022"],
    "types": ["node", "vite/client", "react", "react-dom"],
    "baseUrl": ".",
    "paths": {
      "@do-what/protocol": ["../protocol/src/index.ts"],
      "@do-what/protocol/*": ["../protocol/src/*"]
    },
    "noEmit": true
  },
  "include": ["src/**/*.ts", "src/**/*.tsx", "src/**/*.d.ts", "vite.*.config.ts"]
}
